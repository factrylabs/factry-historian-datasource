{
  "name": "factry-historian-datasource",
  "version": "3.2.1",
  "description": "A datasource plugin for Factry Historian",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "build:dev": "webpack -c ./.config/webpack/webpack.config.ts --env development",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint -- --fix",
    "e2e": "playwright test",
    "server": "docker-compose up --build",
    "sign": "pnpx @grafana/sign-plugin@latest"
  },
  "author": "Factry",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@grafana/eslint-config": "^8.2.0",
    "@grafana/tsconfig": "1.2.0-rc1",
    "@stylistic/eslint-plugin-ts": "^2.9.0",
    "@swc/core": "1.3.75",
    "@swc/helpers": "^0.5.17",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.x",
    "@types/debounce-promise": "^3.1.9",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/node": "^18.19.130",
    "@types/react": "^18.2.25",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.58.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.11.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^50.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-webpack-plugin": "^4.2.0",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^10.5.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^2.8.8",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.97.3",
    "sass-loader": "13.3.1",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2",
    "webpack": "^5.102.1",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2"
  },
  "resolutions": {
    "rxjs": "7.3.0",
    "form-data": "4.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "~11.6.0",
    "@grafana/plugin-e2e": "^1.19.9",
    "@grafana/runtime": "~11.6.0",
    "@grafana/schema": "~11.6.0",
    "@grafana/ui": "~11.6.0",
    "debounce-promise": "^3.1.2",
    "downshift": "^9.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tslib": "2.5.3"
  },
  "packageManager": "pnpm@9.6.0",
  "pnpm": {
    "overrides": {
      "form-data": "4.0.4",
      "rxjs": "7.3.0",
      "immutable": "5.1.5",
      "uplot": "1.6.31",
      "qs": "6.14.1",
      "@remix-run/router": "1.23.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "serialize-javascript": "7.0.3",
      "lodash": "4.18.1",
      "picomatch": "4.0.4",
      "protobufjs@<=8.0.1": "7.5.5"
    }
  }
}
